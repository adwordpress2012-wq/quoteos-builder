{
  "redirects": [
    {
      "source": "/app",
      "destination": "/app/dashboard",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.quoteos.com.au" }],
      "destination": "/app/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
